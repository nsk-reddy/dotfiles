autoload -U +X compinit && compinit
autoload -U +X bashcompinit && bashcompinit
eval "$(starship init zsh)"
export PATH="$HOME/.local/bin:$PATH"
eval "$(duckman completion zsh)"
export PATH="/opt/homebrew/opt/postgresql@17/bin:$PATH"


eval "$(atuin init zsh)"

#. "$HOME/.local/bin/env"

export PATH="/Applications/Cursor.app/Contents/Resources/app/bin:$PATH"



# Load environment variables from ~/.env
if [ -f "$HOME/.env" ]; then
  set -a
  source "$HOME/.env"
  set +a
fi

# NVM (Node Version Manager)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# Google Cloud SDK
export PATH="/opt/homebrew/share/google-cloud-sdk/bin:$PATH"

# fzf keybindings (Ctrl+R history, Ctrl+T files) + zoxide (smart cd)
source <(fzf --zsh)
eval "$(zoxide init zsh)"

# ── Aliases ──────────────────────────────────────────────

# Claude / workspace
alias cc="claude"
alias vcc='cd ~/VS && claude'
alias vs='cd ~/VS'
alias agnes='cd ~/VS/agent-agnes'

# Listing (eza — modern ls)
alias ls='eza --icons'
alias ll='eza -la --icons --git'
alias la='eza -a --icons'
alias lt='eza --tree --icons --level=2'
alias ltt='eza --tree --icons --level=3'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias cd='z'          # zoxide: cd learns your habits (z foo jumps to frecent dir)

# Git
alias gs='git status'
alias ga='git add'
alias gaa='git add -A'
alias gc='git commit'
alias gcm='git commit -m'
alias gp='git push'
alias gpl='git pull'
alias gl='git log --oneline --graph --decorate -15'
alias gd='git diff'
alias gds='git diff --staged'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gb='git branch'
alias gst='git stash'
alias gstp='git stash pop'
alias grh='git reset HEAD'
alias gundo='git reset --soft HEAD~1'

# GitHub CLI
alias prs='gh pr list'
alias prv='gh pr view --web'
alias prc='gh pr create'
alias runs='gh run list --limit 10'

# Dev
alias v='nvim'
alias pn='pnpm'
alias pnd='pnpm dev'
alias pnb='pnpm build'
alias pnt='pnpm test'
alias d='docker'
alias dps='docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"'
alias dlog='docker logs -f'

# Search (ripgrep / fd)
alias grep='rg'
alias findf='fd'

# System / misc
alias mkd='mkdir -p'
alias ports='lsof -i -P -n | grep LISTEN'
alias ip='curl -s ifconfig.me'
alias localip='ipconfig getifaddr en0'
alias reload='source ~/.zshrc'
alias dush='du -sh * | sort -rh | head -15'
alias path='echo $PATH | tr ":" "\n"'
alias hist='atuin search -i'

# Quick kill process on a port: killport 3000
killport() { lsof -ti tcp:"$1" | xargs kill -9 2>/dev/null && echo "killed port $1" || echo "nothing on port $1"; }

# Added by LM Studio CLI (lms)
export PATH="$PATH:/Users/reddy/.lmstudio/bin"
# End of LM Studio CLI section


# opencode
export PATH=/Users/reddy/.opencode/bin:$PATH

# Added by Antigravity
# export PATH="/Users/reddy/.antigravity/antigravity/bin:$PATH"

# caveman default mode (disabled)
# export CAVEMAN_DEFAULT_MODE=ultra


# Added by Antigravity CLI installer
export PATH="/Users/reddy/.local/bin:$PATH"
